            "properties": {
              "data": {
                "description": "Beim Anlegen einer AbsencePeriod, die einen bestehenden manuellen\n`sales_person_unavailable`-Eintrag überdeckt (Forward-Warning,\nBOOK-01, D-Phase3-16: KEIN Auto-Cleanup).",
                "properties": {
                  "absence_id": {
                    "format": "uuid",
                    "type": "string"
                  },
                  "unavailable_id": {
                    "format": "uuid",
                    "type": "string"
                  }
                },
                "required": [
                  "absence_id",
                  "unavailable_id"
                ],
                "type": "object"
              },
              "kind": {
                "enum": [
                  "absence_overlaps_manual_unavailable"
                ],
                "type": "string"
              }
            },
            "required": [
              "data",
              "kind"
            ],
            "type": "object"
          }
        ]
      },
