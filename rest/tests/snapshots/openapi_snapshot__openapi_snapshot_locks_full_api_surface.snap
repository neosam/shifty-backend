        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CopyWeekResultTO"
                }
              }
            },
            "description": "Bookings copied (with cross-source warnings if any)"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "summary": "Phase 3 — konflikt-aware copy_week (D-Phase3-02).",
        "tags": [
          "ShiftplanEdit"
        ]
      }
    },
