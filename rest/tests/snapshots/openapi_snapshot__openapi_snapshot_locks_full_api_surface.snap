        "description": "Permission: HR ∨ `verify_user_is_sales_person(sales_person_id)`\n(D-Phase3-12).",
        "operationId": "get_shiftplan_day_for_sales_person",
        "parameters": [
          {
            "description": "Year of the shift plan",
            "in": "path",
            "name": "year",
            "required": true,
            "schema": {
              "format": "int32",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Calendar week number (1-53)",
            "in": "path",
            "name": "week",
            "required": true,
            "schema": {
              "format": "int32",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Day of the week (Monday, Tuesday, etc.)",
