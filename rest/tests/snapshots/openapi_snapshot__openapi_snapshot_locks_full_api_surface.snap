    "/admin/cutover/commit": {
      "post": {
        "operationId": "cutover_commit_handler",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CutoverRunResultTO"
                }
              }
            },
            "description": "Cutover committed (atomic Tx: migration + carryover refresh + soft-delete + flag-flip)."
          },
          "403": {
            "description": "Caller lacks cutover_admin privilege."
          }
        },
        "tags": [
          "Cutover"
        ]
      }
    },
    "/admin/cutover/gate-dry-run": {
      "post": {
        "operationId": "cutover_gate_dry_run_handler",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CutoverRunResultTO"
                }
              }
            },
            "description": "Dry-run cutover result (Tx rolled back)."
          },
          "403": {
            "description": "Caller lacks HR privilege."
          }
        },
        "tags": [
          "Cutover"
        ]
      }
    },
    "/admin/cutover/profile": {
      "post": {
        "operationId": "cutover_profile_handler",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CutoverProfileTO"
                }
              }
            },
            "description": "Production-data profile generated; JSON file persisted under .planning/migration-backup/."
          },
          "403": {
            "description": "Caller lacks HR privilege."
          }
        },
        "summary": "SC-1 surface — Production-Data-Profile. Read-only from a state perspective\n(the cutover Tx is rolled back inside `profile()`); persists a JSON file\nunder `.planning/migration-backup/profile-{ts}.json` for HR review.\nPermission: HR (matches gate-dry-run; profile is non-destructive).",
        "tags": [
          "Cutover"
        ]
      }
    },
