            ],
            "type": "object"
          },
          {
            "description": "Beim Anlegen eines Bookings auf einem Tag, der durch\n`sales_person_unavailable` abgedeckt ist (Reverse-Warning,\nBOOK-02).",
            "properties": {
              "data": {
                "description": "Beim Anlegen eines Bookings auf einem Tag, der durch\n`sales_person_unavailable` abgedeckt ist (Reverse-Warning,\nBOOK-02).",
                "properties": {
                  "booking_id": {
                    "format": "uuid",
                    "type": "string"
                  },
                  "day_of_week": {
                    "$ref": "#/components/schemas/DayOfWeekTO"
                  },
                  "week": {
                    "format": "int32",
                    "minimum": 0,
