        },
        "summary": "Phase 3 — konflikt-aware Booking-Persist (C-Phase3-09).",
        "tags": [
          "ShiftplanEdit"
        ]
      }
    },
    "/shiftplan-edit/copy-week": {
      "post": {
        "description": "Iteriert über die Bookings der Quell-Woche, ruft pro Source-Booking\nintern `book_slot_with_conflict_check` und aggregiert ALLE Warnings\n(D-Phase3-15: KEINE De-Dup). Permission `shiftplan.edit` (Bulk-Op).",
        "operationId": "copy_week_with_conflict_check",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
